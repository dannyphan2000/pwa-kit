{
    "enabled": true,
    "path": "/store-locator",
    "radius": 100,
    "radiusUnit": "km",
    "defaultPageSize": 10,
    "defaultCountry": "<COUNTRY>",
    "defaultCountryCode": "<COUNTRY_CODE>",
    "defaultPostalCode": "<POSTAL_CODE>",
    "supportedCountries": [
        {
            "countryName": "<COUNTRY>",
            "countryCode": "<COUNTRY_CODE>"
        }
    ],
    "commerceApi": {
        "proxyPath": "/mobify/proxy/api",
        "parameters": {
            "shortCode": "<SHORT_CODE>",
            "clientId": "<CLIENT_ID>",
            "organizationId": "<ORGANIZATION_ID>",
            "siteId": "<SITE_ID>",
            "locale": "<LOCALE>",
            "currency": "<CURRENCY>"
        }
    }
}
